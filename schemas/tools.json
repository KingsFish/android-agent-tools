{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Android Agent Tools",
  "description": "Tool definitions for Android Agent Tools",
  "tools": {
    "read_file": {
      "description": "Read the content of a file at the specified path. Only supports text files.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to the file"
          },
          "encoding": {
            "type": "string",
            "description": "File encoding",
            "default": "utf-8"
          }
        },
        "required": ["path"]
      }
    },
    "write_file": {
      "description": "Write content to a file at the specified path. Creates the file if it does not exist, overwrites if it does.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to the file"
          },
          "content": {
            "type": "string",
            "description": "Content to write to the file"
          },
          "encoding": {
            "type": "string",
            "description": "File encoding",
            "default": "utf-8"
          }
        },
        "required": ["path", "content"]
      }
    },
    "list_directory": {
      "description": "List contents of a directory.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to the directory"
          }
        },
        "required": ["path"]
      }
    },
    "delete_file": {
      "description": "Delete a file at the specified path.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to the file"
          }
        },
        "required": ["path"]
      }
    },
    "file_exists": {
      "description": "Check if a file or directory exists at the specified path.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to check"
          }
        },
        "required": ["path"]
      }
    },
    "list_apps": {
      "description": "List all installed applications on the device.",
      "parameters": {
        "type": "object",
        "properties": {
          "include_system_apps": {
            "type": "boolean",
            "description": "Whether to include system apps",
            "default": false
          }
        },
        "required": []
      }
    },
    "get_app_info": {
      "description": "Get detailed information about an application.",
      "parameters": {
        "type": "object",
        "properties": {
          "package_name": {
            "type": "string",
            "description": "Package name of the application"
          }
        },
        "required": ["package_name"]
      }
    },
    "launch_app": {
      "description": "Launch an application by package name.",
      "parameters": {
        "type": "object",
        "properties": {
          "package_name": {
            "type": "string",
            "description": "Package name of the application to launch"
          }
        },
        "required": ["package_name"]
      }
    },
    "get_device_info": {
      "description": "Get device information including model, OS version, screen size, etc.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    "get_battery_status": {
      "description": "Get current battery status including level, charging state, etc.",
      "parameters": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    "check_permissions": {
      "description": "Check the status of specified permissions.",
      "parameters": {
        "type": "object",
        "properties": {
          "permissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["storage", "camera", "location", "microphone", "contacts", "sms", "phone"]
            },
            "description": "List of permissions to check"
          }
        },
        "required": ["permissions"]
      }
    }
  }
}